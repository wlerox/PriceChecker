{
  "name": "tr-price-compare",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev -w tr-price-compare-server\" \"npm run dev -w tr-price-compare-client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
